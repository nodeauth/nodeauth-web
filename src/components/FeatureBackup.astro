---
import FeatureBlock from './FeatureBlock.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<!-- Backup Feature Block -->
<FeatureBlock
    subtitle={t('feat.backup.subtitle')}
    title={t('feat.backup.title')}
    description={t('feat.backup.desc')}
    buttonText={t('feat.backup.btn')}
    buttonLink={lang === 'en' ? 'https://wiki.nodeauth.io/en/data/backup' : 'https://wiki.nodeauth.io/data/backup'}
    reverse={true}
>
    <div class="mockup-wrapper" style="width: 100%; max-width: 440px; aspect-ratio: 44/36; margin: 0 auto; position: relative;">
        <svg viewBox="0 0 440 360" width="100%" height="100%" style="display: block; overflow: visible;">
            <foreignObject x="0" y="0" width="440" height="360">
                <div class="backup-mockup" style="background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px; width: 440px; height: 360px; box-shadow: var(--shadow-lg); position: relative; overflow: hidden; box-sizing: border-box;">
        <!-- Sync Lines (Star Topology) -->
        <div style="position: absolute; top: 170px; left: 60px; right: 60px; height: 2px; background: var(--border); z-index: 1;"></div>
        <div style="position: absolute; left: 220px; top: 50px; bottom: 50px; width: 2px; background: var(--border); z-index: 1;"></div>
        <div style="position: absolute; left: 220px; top: 170px; width: 400px; height: 2px; background: var(--border); z-index: 1; transform: translate(-50%, -50%) rotate(36.87deg);"></div>
        <div style="position: absolute; left: 220px; top: 170px; width: 400px; height: 2px; background: var(--border); z-index: 1; transform: translate(-50%, -50%) rotate(-36.87deg);"></div>
        
        <!-- Animated sync dots -->
        <div class="anim-sync-tl" style="position: absolute; top: 170px; left: 220px; width: 8px; height: 8px; margin: -4px 0 0 -4px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 10px var(--accent); z-index: 2;"></div>
        <div class="anim-sync-tc" style="position: absolute; top: 170px; left: 220px; width: 8px; height: 8px; margin: -4px 0 0 -4px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 10px var(--accent); z-index: 2;"></div>
        <div class="anim-sync-tr" style="position: absolute; top: 170px; left: 220px; width: 8px; height: 8px; margin: -4px 0 0 -4px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 10px var(--accent); z-index: 2;"></div>
        <div class="anim-sync-cl" style="position: absolute; top: 170px; left: 220px; width: 8px; height: 8px; margin: -4px 0 0 -4px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 10px var(--accent); z-index: 2;"></div>
        <div class="anim-sync-cr" style="position: absolute; top: 170px; left: 220px; width: 8px; height: 8px; margin: -4px 0 0 -4px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 10px var(--accent); z-index: 2;"></div>
        <div class="anim-sync-bl" style="position: absolute; top: 170px; left: 220px; width: 8px; height: 8px; margin: -4px 0 0 -4px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 10px var(--accent); z-index: 2;"></div>
        <div class="anim-sync-bc" style="position: absolute; top: 170px; left: 220px; width: 8px; height: 8px; margin: -4px 0 0 -4px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 10px var(--accent); z-index: 2;"></div>
        <div class="anim-sync-br" style="position: absolute; top: 170px; left: 220px; width: 8px; height: 8px; margin: -4px 0 0 -4px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 10px var(--accent); z-index: 2;"></div>

        <!-- Center node -->
        <div style="position: absolute; top: 170px; left: 220px; margin: -26px 0 0 -26px; width: 52px; height: 52px; background: var(--accent); border-radius: 14px; display: flex; align-items: center; justify-content: center; z-index: 4; box-shadow: 0 8px 24px rgba(0,113,227,0.4);">
            <img src="/logo.svg" width="28" height="28" alt="NodeAuth" style="border-radius: 8px; filter: brightness(0) invert(1);" />
        </div>

        <!-- TL: Telegram -->
        <div style="position: absolute; top: 50px; left: 60px; margin: -24px 0 0 -24px; width: 48px; display: flex; flex-direction: column; align-items: center; gap: 4px; z-index: 3; font-size: 0.65rem; font-weight: 600; color: var(--text-primary);">
            <div style="width: 36px; height: 36px; background: var(--bg-color); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-sm);">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#24A1DE"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12a12 12 0 0 0 12-12A12 12 0 0 0 11.944 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472c-.18 1.898-.962 6.502-1.36 8.627c-.168.9-.499 1.201-.82 1.23c-.696.065-1.225-.46-1.9-.902c-1.056-.693-1.653-1.124-2.678-1.8c-1.185-.78-.417-1.21.258-1.91c.177-.184 3.247-2.977 3.307-3.23c.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345c-.48.33-.913.49-1.302.48c-.428-.008-1.252-.241-1.865-.44c-.752-.245-1.349-.374-1.297-.789c.027-.216.325-.437.893-.663c3.498-1.524 5.83-2.529 6.998-3.014c3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
            </div>
            Telegram
        </div>

        <!-- TC: SMTP (Mail icon) -->
        <div style="position: absolute; top: 50px; left: 220px; margin: -24px 0 0 -24px; width: 48px; display: flex; flex-direction: column; align-items: center; gap: 4px; z-index: 3; font-size: 0.65rem; font-weight: 600; color: var(--text-primary);">
            <div style="width: 36px; height: 36px; background: var(--bg-color); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-sm); color: var(--text-primary);">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#D44638" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </div>
            SMTP
        </div>

        <!-- TR: Baidu -->
        <div style="position: absolute; top: 50px; left: 380px; margin: -24px 0 0 -24px; width: 48px; display: flex; flex-direction: column; align-items: center; gap: 4px; z-index: 3; font-size: 0.65rem; font-weight: 600; color: var(--text-primary);">
            <div style="width: 36px; height: 36px; background: var(--bg-color); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-sm);">
                <svg width="18" height="18" viewBox="0 0 100 100" fill="#06A7E1"><path d="M88.6,46.1c-4.6-4.6-10.8-6.7-16.8-6.3c0.4-6-1.7-12.2-6.3-16.8c-8.5-8.5-22.4-8.5-30.9,0 c-4.6,4.6-6.7,10.8-6.3,16.8c-6-0.4-12.2,1.7-16.8,6.3c-8.5,8.5-8.5,22.4,0,30.9s22.4,8.5,30.9,0l14.3-14.3l1.1-1.1l7.7-7.7 c4.3-4.3,11.2-4.3,15.4,0s4.3,11.2,0,15.4c-4.3,4.3-11.2,4.3-15.4,0c-2.1-2.1-5.6-2.1-7.7,0s-2.1,5.6,0,7.7 c8.5,8.5,22.4,8.5,30.9,0C97.1,68.5,97.1,54.7,88.6,46.1z M19.1,69.3c-4.3-4.3-4.3-11.2,0-15.4c4.3-4.3,11.2-4.3,15.4,0 s4.3,11.2,0,15.4C30.3,73.6,23.4,73.6,19.1,69.3z M42.3,46.1C38,41.9,38,35,42.3,30.7c4.3-4.3,11.2-4.3,15.4,0s4.3,11.2,0,15.4 C53.5,50.4,46.5,50.4,42.3,46.1z"/></svg>
            </div>
            Baidu
        </div>

        <!-- CL: WebDAV -->
        <div style="position: absolute; top: 170px; left: 60px; margin: -24px 0 0 -24px; width: 48px; display: flex; flex-direction: column; align-items: center; gap: 4px; z-index: 3; font-size: 0.65rem; font-weight: 600; color: var(--text-primary);">
            <div style="width: 36px; height: 36px; background: var(--bg-color); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-sm); color: var(--text-primary);">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect><rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect><line x1="6" y1="6" x2="6.01" y2="6"></line><line x1="6" y1="18" x2="6.01" y2="18"></line></svg>
            </div>
            WebDAV
        </div>

        <!-- CR: S3/R2 (Database icon) -->
        <div style="position: absolute; top: 170px; left: 380px; margin: -24px 0 0 -24px; width: 48px; display: flex; flex-direction: column; align-items: center; gap: 4px; z-index: 3; font-size: 0.65rem; font-weight: 600; color: var(--text-primary);">
            <div style="width: 36px; height: 36px; background: var(--bg-color); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-sm); color: var(--text-primary);">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#F48120" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path></svg>
            </div>
            S3 / R2
        </div>

        <!-- BL: Dropbox -->
        <div style="position: absolute; top: 290px; left: 60px; margin: -24px 0 0 -24px; width: 48px; display: flex; flex-direction: column; align-items: center; gap: 4px; z-index: 3; font-size: 0.65rem; font-weight: 600; color: var(--text-primary);">
            <div style="width: 36px; height: 36px; background: var(--bg-color); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-sm);">
                <svg width="20" height="20" viewBox="0 0 1333.34 1133.07" fill="#0061FF"><path d="M667.53 212.92L333.76 425.84l333.77 212.92-333.77 212.92L0 637.61l333.76-212.92L0 212.92 333.76 0l333.77 212.92zM332.04 920.15L665.8 707.23l333.76 212.92-333.76 212.92-333.76-212.92zM667.53 637.6l333.76-212.92-333.76-211.77L999.57-.01l333.77 212.92-333.77 212.92 333.77 212.92-333.77 212.92L667.53 637.6z"/></svg>
            </div>
            Dropbox
        </div>

        <!-- BC: Google Drive -->
        <div style="position: absolute; top: 290px; left: 220px; margin: -24px 0 0 -24px; width: 48px; display: flex; flex-direction: column; align-items: center; gap: 4px; z-index: 3; font-size: 0.65rem; font-weight: 600; color: var(--text-primary);">
            <div style="width: 36px; height: 36px; background: var(--bg-color); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-sm);">
                <svg width="20" height="20" viewBox="0 0 122.88 109.79"><path fill="#0066DA" d="M9.29,94.1l5.42,9.36c1.13,1.97,2.74,3.52,4.65,4.64l19.35-33.5H0c0,2.18,0.56,4.36,1.69,6.33L9.29,94.1z"/><path fill="#00AC47" d="M61.44,35.19L42.09,1.69c-1.9,1.13-3.52,2.67-4.65,4.65L1.69,68.27C0.59,70.19,0,72.38,0,74.6l38.71,0 L61.44,35.19z"/><path fill="#EA4335" d="M103.53,108.1c1.9-1.13,3.52-2.67,4.65-4.64l2.25-3.87l10.77-18.65c1.13-1.97,1.69-4.15,1.69-6.33H84.17 l8.24,16.19L103.53,108.1z"/><path fill="#00AC47" d="M61.44,35.19l19.35-33.5C78.89,0.56,76.71,0,74.46,0H48.42c-2.25,0-4.43,0.63-6.33,1.69L61.44,35.19z"/><path fill="#FFBA00" d="M84.17,74.6H38.71l-19.35,33.5c1.9,1.13,4.08,1.69,6.33,1.69h71.5c2.25,0,4.44-0.63,6.33-1.69L84.17,74.6z"/><path fill="#FFBA00" d="M103.31,37.3L85.44,6.33c-1.13-1.97-2.74-3.52-4.64-4.65l-19.35,33.5L84.17,74.6h38.64 c0-2.18-0.56-4.36-1.69-6.33L103.31,37.3z"/></svg>
            </div>
            Drive
        </div>

        <!-- BR: OneDrive -->
        <div style="position: absolute; top: 290px; left: 380px; margin: -24px 0 0 -24px; width: 48px; display: flex; flex-direction: column; align-items: center; gap: 4px; z-index: 3; font-size: 0.65rem; font-weight: 600; color: var(--text-primary);">
            <div style="width: 36px; height: 36px; background: var(--bg-color); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-sm);">
                <svg width="20" height="20" viewBox="0 0 512 512" fill="#0078D4"><path d="M309.32,313.35L415,212.28c-21.95-85.6-109.14-137.19-194.74-115.24c-38.55,9.89-72.03,33.78-93.91,67.02 C128,164.02,309.32,313.35,309.32,313.35z"/><path d="M195.24,183.09l0,0.02c-20.19-12.51-43.48-19.12-67.24-19.09c-0.55,0-1.09,0.03-1.64,0.04 C55.7,164.94-0.86,222.93,0.01,293.58c0.32,25.63,8.33,50.57,22.99,71.6l158.33-19.83l121.39-97.88L195.24,183.09z"/><path d="M415,212.28c-2.32-0.16-4.66-0.26-7.02-0.26c-14.18-0.01-28.21,2.88-41.22,8.51l0-0.01l-64.04,26.95 l70.6,87.21l126.22,30.68c27.24-50.57,8.33-113.64-42.24-140.88C444.23,217.45,429.81,213.29,415,212.28L415,212.28L415,212.28z"/><path d="M23,365.18c23.91,34.37,63.13,54.86,105,54.83h279.99c38.25,0.01,73.41-20.98,91.56-54.65l-196.83-117.9 L23,365.18z"/></svg>
            </div>
            OneDrive
        </div>
        
        <div style="position: absolute; bottom: 20px; left: 0; right: 0; text-align: center; font-size: 0.85rem; font-weight: 500; color: var(--text-secondary); display: flex; justify-content: center; align-items: center; gap: 8px;">
            <div class="anim-blink" style="width: 8px; height: 8px; background: #10b981; border-radius: 50%; box-shadow: 0 0 8px #10b981;"></div>
            Syncing to 8 remote sources
        </div>
                </div>
            </foreignObject>
        </svg>
    </div>
</FeatureBlock>

<style>
.anim-sync-up { animation: syncUp 2.5s infinite cubic-bezier(0.4, 0, 0.2, 1); }
.anim-sync-down { animation: syncDown 2.5s infinite cubic-bezier(0.4, 0, 0.2, 1); animation-delay: 0.6s; }
.anim-sync-left { animation: syncLeft 2.5s infinite cubic-bezier(0.4, 0, 0.2, 1); animation-delay: 1.2s; }
.anim-sync-right { animation: syncRight 2.5s infinite cubic-bezier(0.4, 0, 0.2, 1); animation-delay: 1.8s; }

@keyframes syncUp {
    0% { transform: translate(0, 0) scale(0.5); opacity: 0; }
    15% { opacity: 1; transform: translate(0, -20px) scale(1); }
    85% { opacity: 1; transform: translate(0, -90px) scale(1); }
    100% { transform: translate(0, -110px) scale(0.5); opacity: 0; }
}
@keyframes syncDown {
    0% { transform: translate(0, 0) scale(0.5); opacity: 0; }
    15% { opacity: 1; transform: translate(0, 20px) scale(1); }
    85% { opacity: 1; transform: translate(0, 70px) scale(1); }
    100% { transform: translate(0, 90px) scale(0.5); opacity: 0; }
}
@keyframes syncLeft {
    0% { transform: translate(0, 0) scale(0.5); opacity: 0; }
    15% { opacity: 1; transform: translate(-30px, 0) scale(1); }
    85% { opacity: 1; transform: translate(-150px, 0) scale(1); }
    100% { transform: translate(-170px, 0) scale(0.5); opacity: 0; }
}
@keyframes syncRight {
    0% { transform: translate(0, 0) scale(0.5); opacity: 0; }
    15% { opacity: 1; transform: translate(30px, 0) scale(1); }
    85% { opacity: 1; transform: translate(140px, 0) scale(1); }
    100% { transform: translate(160px, 0) scale(0.5); opacity: 0; }
}

@keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
}
.anim-blink { animation: blink 2s infinite; }
</style>

<style is:global>
.anim-sync-tl { animation: syncTL 2.5s infinite cubic-bezier(0.4, 0, 0.2, 1); animation-delay: 0.1s; }
.anim-sync-tc { animation: syncTC 2.5s infinite cubic-bezier(0.4, 0, 0.2, 1); animation-delay: 0.8s; }
.anim-sync-tr { animation: syncTR 2.5s infinite cubic-bezier(0.4, 0, 0.2, 1); animation-delay: 0.4s; }
.anim-sync-cl { animation: syncCL 2.5s infinite cubic-bezier(0.4, 0, 0.2, 1); animation-delay: 1.2s; }
.anim-sync-cr { animation: syncCR 2.5s infinite cubic-bezier(0.4, 0, 0.2, 1); animation-delay: 1.5s; }
.anim-sync-bl { animation: syncBL 2.5s infinite cubic-bezier(0.4, 0, 0.2, 1); animation-delay: 0.6s; }
.anim-sync-bc { animation: syncBC 2.5s infinite cubic-bezier(0.4, 0, 0.2, 1); animation-delay: 1.8s; }
.anim-sync-br { animation: syncBR 2.5s infinite cubic-bezier(0.4, 0, 0.2, 1); animation-delay: 1.0s; }

@keyframes syncTL { 0% { transform: translate(0,0) scale(0.5); opacity:0; } 15% { opacity:1; transform: translate(-24px,-18px) scale(1); } 85% { opacity:1; transform: translate(-136px,-102px) scale(1); } 100% { transform: translate(-160px,-120px) scale(0.5); opacity:0; } }
@keyframes syncTC { 0% { transform: translate(0,0) scale(0.5); opacity:0; } 15% { opacity:1; transform: translate(0,-18px) scale(1); } 85% { opacity:1; transform: translate(0,-102px) scale(1); } 100% { transform: translate(0,-120px) scale(0.5); opacity:0; } }
@keyframes syncTR { 0% { transform: translate(0,0) scale(0.5); opacity:0; } 15% { opacity:1; transform: translate(24px,-18px) scale(1); } 85% { opacity:1; transform: translate(136px,-102px) scale(1); } 100% { transform: translate(160px,-120px) scale(0.5); opacity:0; } }
@keyframes syncCL { 0% { transform: translate(0,0) scale(0.5); opacity:0; } 15% { opacity:1; transform: translate(-24px,0) scale(1); } 85% { opacity:1; transform: translate(-136px,0) scale(1); } 100% { transform: translate(-160px,0) scale(0.5); opacity:0; } }
@keyframes syncCR { 0% { transform: translate(0,0) scale(0.5); opacity:0; } 15% { opacity:1; transform: translate(24px,0) scale(1); } 85% { opacity:1; transform: translate(136px,0) scale(1); } 100% { transform: translate(160px,0) scale(0.5); opacity:0; } }
@keyframes syncBL { 0% { transform: translate(0,0) scale(0.5); opacity:0; } 15% { opacity:1; transform: translate(-24px,18px) scale(1); } 85% { opacity:1; transform: translate(-136px,102px) scale(1); } 100% { transform: translate(-160px,120px) scale(0.5); opacity:0; } }
@keyframes syncBC { 0% { transform: translate(0,0) scale(0.5); opacity:0; } 15% { opacity:1; transform: translate(0,18px) scale(1); } 85% { opacity:1; transform: translate(0,102px) scale(1); } 100% { transform: translate(0,120px) scale(0.5); opacity:0; } }
@keyframes syncBR { 0% { transform: translate(0,0) scale(0.5); opacity:0; } 15% { opacity:1; transform: translate(24px,18px) scale(1); } 85% { opacity:1; transform: translate(136px,102px) scale(1); } 100% { transform: translate(160px,120px) scale(0.5); opacity:0; } }
</style>
