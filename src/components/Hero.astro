---
// src/components/Hero.astro
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<section class="hero section-wrapper">
    <!-- 柔和背景光晕 -->
    <div class="glow-orb orb-left"></div>
    <div class="glow-orb orb-right"></div>
    
    <a href="https://license.nodeauth.io/buy?coupon_code=EARLYBIRD20" target="_blank" rel="noopener noreferrer" class="hero-banner">
        🎉 {t('hero.tag')}
    </a>
    <h1 class="hero-title" set:html={t('hero.title')}></h1>
    <p class="section-desc">{t('hero.desc')}</p>
    
    <!-- 卖点打勾列表 -->
    <div class="hero-features">
        <span><span class="check">✓</span> {t('hero.f1')}</span>
        <span><span class="check">✓</span> {t('hero.f2')}</span>
        <span><span class="check">✓</span> {t('hero.f3')}</span>
    </div>

    <div class="hero-actions">
        <a href="#license" class="btn-primary">{t('hero.buy')}</a>
        <a href="https://demo.nodeauth.io" target="_blank" rel="noopener noreferrer" class="btn-secondary">{t('hero.demo')}</a>
    </div>
</section>

<style>
.hero {
    padding-top: clamp(6rem, 8vw, 7.5rem);
    padding-bottom: clamp(1rem, 3vw, 2rem);
    position: relative;
    max-width: none; /* override section-wrapper max-width for background if needed, but keeping it centered is fine */
    overflow: hidden;
}

/* 柔和背景光晕 (Mesh Gradient Orbs) */
.glow-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.6;
    z-index: -1;
    pointer-events: none;
}
.orb-left {
    width: 450px;
    height: 450px;
    background: #e0e7ff; /* 淡紫蓝色 */
    top: 5%;
    left: calc(50% - 600px);
}
:global([data-theme='dark']) .orb-left {
    background: rgba(59, 130, 246, 0.15);
}
.orb-right {
    width: 550px;
    height: 550px;
    background: #fae8ff; /* 淡粉色 */
    bottom: -20%;
    right: calc(50% - 600px);
}
:global([data-theme='dark']) .orb-right {
    background: rgba(236, 72, 153, 0.15);
}

.hero-title {
    font-size: clamp(2.2rem, 8vw, 6rem);
    font-weight: 800;
    letter-spacing: clamp(-2px, -0.3vw, -3.5px);
    line-height: 1.1;
    margin-bottom: clamp(1rem, 3vw, 1.5rem);
    color: var(--text-primary);
}

:global(.text-gradient) {
    background: linear-gradient(135deg, #d946ef 0%, #8b5cf6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.hero-banner {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 113, 227, 0.05);
    color: var(--accent);
    padding: clamp(0.4rem, 1.5vw, 0.5rem) clamp(0.8rem, 2vw, 1.2rem);
    border-radius: 980px;
    font-size: clamp(0.7rem, 2.5vw, 0.9rem);
    font-weight: 600;
    margin-bottom: clamp(1rem, 2vw, 1.5rem);
    border: 1px solid rgba(0, 113, 227, 0.1);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    line-height: 1.4;
    text-align: center;
    text-decoration: none;
    white-space: nowrap;
}

.hero-banner:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(0, 113, 227, 0.1);
}

:global([data-theme='dark']) .hero-banner {
    background: rgba(10, 132, 255, 0.1);
    border-color: rgba(10, 132, 255, 0.2);
}
.hero-banner:hover {
    transform: translateY(-2px);
}

.hero-features {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: clamp(0.5rem, 2.5vw, 2rem);
    margin-bottom: clamp(1.5rem, 3vw, 2rem);
    font-size: clamp(0.95rem, 2vw, 1.05rem);
    color: var(--text-secondary);
    font-weight: 500;
}

.hero-features .check {
    color: #10b981;
    margin-right: 0.4rem;
    font-weight: bold;
}

.hero-actions {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
}

@media (max-width: 768px) {
    .hero-features { 
        flex-direction: column; 
        align-items: flex-start;
        display: inline-flex;
    }
    .hero-actions { flex-direction: column; width: 100%; }
    .hero-actions a { width: 100%; }
    .orb-left, .orb-right { width: 300px; height: 300px; filter: blur(60px); }
}
</style>
