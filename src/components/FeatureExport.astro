---
import FeatureBlock from './FeatureBlock.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<!-- Export Feature Block -->
<FeatureBlock
    subtitle={t('feat.export.subtitle')}
    title={t('feat.export.title')}
    description={t('feat.export.desc')}
    buttonText={t('feat.export.btn')}
    buttonLink={lang === 'en' ? 'https://wiki.nodeauth.io/en/data/export' : 'https://wiki.nodeauth.io/data/export'}
>
    <div class="mockup-container" style="background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; max-width: 480px; margin: 0 auto; box-shadow: var(--shadow-lg); text-align: left;">
        <div style="background: var(--bg-color); border-bottom: 1px solid var(--border); padding: 12px 16px; display: flex; justify-content: space-between; align-items: center;">
            <div style="display: flex; gap: 8px;">
                <div style="width: 12px; height: 12px; border-radius: 50%; background: #ff5f56; box-shadow: inset 0 0 4px rgba(0,0,0,0.1);"></div>
                <div style="width: 12px; height: 12px; border-radius: 50%; background: #ffbd2e; box-shadow: inset 0 0 4px rgba(0,0,0,0.1);"></div>
                <div style="width: 12px; height: 12px; border-radius: 50%; background: #27c93f; box-shadow: inset 0 0 4px rgba(0,0,0,0.1);"></div>
            </div>
            <div style="font-size: 0.8rem; color: var(--text-secondary); font-family: monospace; font-weight: 500;">nodeauth-export.json</div>
        </div>
        <div style="padding: 24px; font-family: 'SFMono-Regular', Consolas, monospace; font-size: 0.9rem; color: var(--text-primary); background: var(--card-bg); position: relative; min-height: 200px;">
            <div>[</div>
            <div style="padding-left: 20px;">&#123;</div>
            <div style="padding-left: 40px;"><span style="color: var(--subtitle-color);">"issuer"</span>: <span style="color: #10b981;">"GitHub"</span>,</div>
            <div style="padding-left: 40px;"><span style="color: var(--subtitle-color);">"account"</span>: <span style="color: #10b981;">"alice@github"</span>,</div>
            <div style="padding-left: 40px;"><span style="color: var(--subtitle-color);">"secret"</span>: <span style="color: #10b981;">"****************"</span></div>
            <div style="padding-left: 20px;">&#125;</div>
            <div>]</div>
            <!-- Animated Download Icon -->
            <div class="anim-download" style="position: absolute; bottom: 20px; right: 20px; background: var(--accent); color: white; width: 44px; height: 44px; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 12px rgba(0,113,227,0.3);">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
            </div>
        </div>
    </div>
</FeatureBlock>

<style>
@keyframes downloadBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
}
.anim-download {
    animation: downloadBounce 2s infinite;
}
@keyframes pulseBorder {
    0% { border-color: var(--border); }
    50% { border-color: var(--accent); box-shadow: inset 0 0 20px rgba(0,113,227,0.05); }
    100% { border-color: var(--border); }
}
.anim-pulse-border {
    animation: pulseBorder 3s infinite;
}
</style>
