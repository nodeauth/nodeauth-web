---
// src/components/Footer.astro
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<footer>
    <div class="footer-container">
        <div class="footer-brand">
            <div class="logo">NodeAuth</div>
            <p set:html={t('footer.desc')}></p>
        </div>
        
        <div class="footer-links-grid">
            <div class="footer-col">
                <h4>{t('footer.col1.title')}</h4>
                <a href="https://license.nodeauth.io" target="_blank" rel="noopener noreferrer">{t('footer.col1.l1')}</a>
                <a href="/#extension">{t('footer.col1.l2')}</a>
            </div>
            
            <div class="footer-col">
                <h4>{t('footer.col2.title')}</h4>
                <a href="https://demo.nodeauth.io" target="_blank" rel="noopener noreferrer">{t('footer.col2.l1')}</a>
                <a href="https://wiki.nodeauth.io" target="_blank" rel="noopener noreferrer">{t('footer.col2.l2')}</a>
                <a href="https://tools.nodeauth.io" target="_blank" rel="noopener noreferrer">{t('footer.col2.l3')}</a>
            </div>

            <div class="footer-col">
                <h4>{t('footer.col3.title')}</h4>
                <a href={lang === 'en' ? '/en/terms' : '/terms'}>{t('footer.col3.l1')}</a>
                <a href={lang === 'en' ? '/en/privacy' : '/privacy'}>{t('footer.col3.l2')}</a>
            </div>

            <div class="footer-col">
                <h4>{t('footer.col4.title')}</h4>
                <a href="mailto:support@nodeauth.io">{t('footer.col4.l1')}</a>
                <a href="https://t.me/NodeauthGroup" target="_blank" rel="noopener noreferrer">{t('footer.col4.l2')}</a>
            </div>
        </div>
    </div>

    <div class="footer-bottom">
        <p class="copyright" set:html={t('footer.rights')}></p>
    </div>
</footer>

<style>
/* 7. Footer */
footer {
    position: relative;
    padding: clamp(3rem, 8vw, 5rem) clamp(1rem, 5vw, 2rem) 2rem;
    background-color: var(--bg-color); /* Matches the image's light gray background */
    color: var(--text-secondary);
    font-size: 0.95rem;
    border-top: 1px solid var(--border);
}

.footer-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 clamp(1rem,5vw,2rem);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 3rem;
}

.footer-brand {
    flex: 1 1 300px;
    text-align: left;
}

.footer-brand .logo {
    font-weight: 700; 
    font-size: 1.3rem; 
    color: var(--text-primary); 
    margin-bottom: 0.8rem;
}

.footer-brand p {
    margin-bottom: 1rem;
    line-height: 1.6;
}

.footer-bottom {
    max-width: 1440px;
    margin: 3rem auto 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    text-align: center;
}

.footer-bottom .copyright {
    font-size: 0.85rem;
    color: var(--text-secondary);
}

.footer-links-grid {
    display: flex;
    flex: 2 1 600px;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 2rem;
}

.footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    text-align: left;
    min-width: 120px;
}

.footer-col h4 {
    color: var(--text-primary);
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
    font-weight: 600;
}

.footer-col a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s;
}

.footer-col a:hover {
    color: var(--text-primary);
}

@media (max-width: 768px) {
    .footer-container {
        flex-direction: column;
    }
    
    .footer-brand {
        flex: 1 1 auto;
    }
    
    .footer-links-grid {
        justify-content: flex-start;
        flex: 1 1 auto;
    }
}
</style>
